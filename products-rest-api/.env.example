# Environment variables configuration
# Copy this file to .env and update with your actual values

# Server Configuration
SERVER_NAME=Products REST API
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# Database Configuration
# PostgreSQL connection string format (async with psycopg):
# postgresql+psycopg_async://username:password@hostname:port/database
# For local development:
DATABASE_URL=postgresql+psycopg_async://products_user:products_password@localhost:5432/products_db

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Logging
LOG_LEVEL=INFO
